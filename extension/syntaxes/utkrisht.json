{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Utkrisht",
    "patterns": [
        {
            "include": "#keywords"
        },
        {
            "include": "#comment"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#number"
        },
        {
            "include": "#constant"
        },
        {
            "include": "#parameter"
        },
        {
            "include": "#function"
        },
        {
            "include": "#variable"
        },
        {
            "include": "#meta"
        },
        {
            "include": "#type"
        }
    ],
    "repository": {
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control",
                    "match": "(?<!-|\\d|[a-z])(try|fix|crash|when|else|loop|with|exit|skip|return|import|export)(?!-|\\d|[a-z])"
                },
                {
                    "name": "constant.language",
                    "match": "(?<!-|\\w|\\d)(yes|no|nan|infinity|-infinity)(?!-|\\w|\\d)"
                }
            ]
        },
        "variable": {
            "patterns": [
                {
                    "name": "variable.name",
                    "match": "[a-z](?:[a-z]|[0-9]|-(?!-))*[a-z0-9]?"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.utkrisht",
                    "begin": "\"",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.begin"
                        }
                    },
                    "end": "\"",
                    "endCaptures": {
                        "0": {
                            "name": "punctuation.definition.string.end"
                        }
                    },
                    "patterns": [
                        {
                            "name": "constant.character.escape.utkrisht",
                            "match": "\\\\(\"|\\\\|\\||n|r|t|b|f|v|0|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|u\\{[0-9A-Fa-f]+\\})"
                        },
                        {
                            "name": "string.interpolated.utkrisht",
                            "begin": "\\|",
                            "beginCaptures": {
                                "0": {
                                    "name": "punctuation.definition.template-expression.begin"
                                }
                            },
                            "end": "\\|",
                            "endCaptures": {
                                "0": {
                                    "name": "punctuation.definition.template-expression.end"
                                }
                            },
                            "patterns": [
                                {
                                    "include": "$self"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "comment": {
            "name": "comment",
            "begin": "# ",
            "end": "\\n"
        },
        "number": {
            "patterns": [
                {
                    "name": "constant.numeric.utkrisht",
                    "match": "(?<![a-zA-Z])\\b\\d+(?:[.-]\\d+)*\\b"
                }
            ]
        },
        "function": {
            "patterns": [
                {
                    "name": "entity.name.function",
                    "match": "[a-z](?:[a-z]|[0-9]|-(?!-))*[a-z0-9]?(?= -\\d| +\\d|\\*| [a-z0-9A-Z\"\\[\\(])(?! with)"
                },
                {
                    "name": "entity.name.function",
                    "match": "(?<=^\\s*)[a-z](?:[a-z]|[0-9]|-(?!-))*[a-z0-9]? = *(\\{)"
                },
                {
                    "name": "entity.name.function",
                    "match": "(?:webapp|shape|text|media|tag)"
                }
            ]
        },
        "parameter": {
            "patterns": [
                {
                    "name": "",
                    "match": "[a-z](?:[a-z0-9-]*[a-z0-9])?(?=:)"
                },
                {
                    "name": "",
                    "match": "[a-z](?:[a-z0-9-]*[a-z0-9])?(\\.)?[a-z](?:[a-z0-9-]*[a-z0-9])?(?=:)"
                }
            ]
        },
        "meta": {
            "patterns": [
                {
                    "name": "meta.preprocessor.macro",
                    "match": "#[a-z](?:[a-z0-9-]*[a-z0-9])?"
                }
            ]
        },
        "type": {
            "patterns": [
                {
                    "name": "entity.name.type",
                    "match": "[A-Z](?:[a-z]|[0-9]|-(?!-))*[a-z0-9]?"
                }
            ]
        }
    },
    "scopeName": "source.utkrisht"
}